# Copy this file to .env and set your Laravel API URL.
# When VITE_API_URL is set, the React app uses Laravel + MySQL (smartloc).
# When empty or missing, the app uses mock data and localStorage.

# Laravel API base URL (no trailing slash)
# Examples: http://localhost:8000  |  http://127.0.0.1:8000  |  http://smartloc-backend.test
VITE_API_URL=http://localhost:8000
