{
  "name": "smartloc-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:laravel": "php backend/artisan serve --host=127.0.0.1 --port=8000",
