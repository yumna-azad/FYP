# Production build config (loaded automatically by `vite build` on Vercel).
# These VITE_ values are public by design — they get baked into the client
# bundle. No secrets here.

# Auth: left empty so the hosted site runs in demo mode (any email/password
# logs in, no Laravel backend required online). See src/context/AuthContext.jsx.
VITE_API_URL=

# ML recommendations: point at the live Hugging Face Space (model API).
VITE_ML_API_URL=https://yumnaazad-smartloc-ml.hf.space

# Chatbot: no Gemini key in production, so it uses the grounded local assistant
# instantly (no failed API round-trip). Model name kept current in case a
# billed key is added later via the Vercel dashboard.
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.0-flash
